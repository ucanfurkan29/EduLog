@model EduLog.Web.ViewModels.StudentClassDetailViewModel
@{
    ViewData["Title"] = Model.ClassName;
    Layout = "~/Views/Shared/_LayoutStudent.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">
            <i class="bi bi-book me-2"></i> @Model.ClassName
        </h3>
        <p class="text-muted mb-0">@Model.CourseName — Ders @Model.CurrentWeek</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Sınıflarıma Dön
    </a>
</div>

<!-- Score Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #e3f2fd, #bbdefb);">
            <div class="card-body p-4 d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 56px; height: 56px;">
                    <i class="bi bi-star-fill text-primary fs-4"></i>
                </div>
                <div>
                    <p class="text-muted small mb-0">Toplam Puanın</p>
                    <h3 class="fw-bold mb-0 text-primary">@Model.TotalScore</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #fff3e0, #ffe0b2);">
            <div class="card-body p-4 d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 56px; height: 56px;">
                    <i class="bi bi-trophy-fill text-warning fs-4"></i>
                </div>
                <div>
                    <p class="text-muted small mb-0">Sınıf Sıralaması</p>
                    <h3 class="fw-bold mb-0 text-warning">#@Model.ClassRank</h3>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!Model.OpenWeeks.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-lock text-muted" style="font-size: 4rem;"></i>
        <p class="text-muted mt-3 fs-5">Henüz açılmış hafta bulunmuyor.</p>
        <p class="text-muted small">Eğitmeniniz haftaları sırayla açacaktır.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var week in Model.OpenWeeks)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                                <span class="fw-bold text-success">@week.WeekNumber</span>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="fw-bold mb-0">Ders @week.WeekNumber</h6>
                                <small class="text-muted">@week.Topic</small>
                            </div>
                            @if (week.WeekScore > 0)
                            {
                                <span class="badge bg-success px-2 py-1">
                                    <i class="bi bi-star-fill me-1"></i> @week.WeekScore puan
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary px-2 py-1">0 puan</span>
                            }
                        </div>
                        <a asp-action="WeekDetail"
                           asp-route-classGroupId="@Model.ClassGroupId"
                           asp-route-weekNumber="@week.WeekNumber"
                           class="btn btn-outline-success btn-sm w-100">
                            <i class="bi bi-eye me-1"></i> Detay
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
