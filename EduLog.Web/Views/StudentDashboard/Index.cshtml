@model List<EduLog.Web.ViewModels.StudentClassViewModel>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_LayoutStudent.cshtml";
}

<div class="row mb-4">
    <div class="col-12">
        <h3 class="fw-bold">
            <i class="bi bi-speedometer2 me-2"></i> Öğrenci Paneli
        </h3>
        <p class="text-muted">Hoş geldiniz! Kayıtlı olduğunuz sınıflarınız aşağıda listelenmiştir.</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-journal-x text-muted" style="font-size: 4rem;"></i>
        <p class="text-muted mt-3 fs-5">Henüz bir sınıfa kayıtlı değilsiniz.</p>
        <p class="text-muted small">Eğitmeninizden aldığınız katılım kodu ile kayıt olabilirsiniz.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width: 48px; height: 48px;">
                            <i class="bi bi-book text-primary fs-5"></i>
                        </div>
                        <h5 class="fw-bold mb-1">@item.ClassName</h5>
                        <p class="text-muted small mb-3">@item.CourseName</p>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="badge bg-info bg-opacity-10 text-info px-3 py-2">
                                <i class="bi bi-calendar-week me-1"></i> Hafta @item.CurrentWeek
                            </span>
                        </div>
                        <a asp-action="ClassDetail" asp-route-id="@item.ClassGroupId"
                           class="btn btn-outline-primary btn-sm w-100">
                            <i class="bi bi-eye me-1"></i> Sınıf Detayı
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
