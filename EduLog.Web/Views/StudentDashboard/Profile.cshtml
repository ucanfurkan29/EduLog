@model EduLog.Web.ViewModels.StudentProfileViewModel
@{
    ViewData["Title"] = "Profilim";
    Layout = "~/Views/Shared/_LayoutStudent.cshtml";
}

<!-- Profile Header -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center gap-4">
                    <div class="rounded-circle bg-white bg-opacity-25 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; min-width: 80px;">
                        <i class="bi bi-person-fill text-white" style="font-size: 2.5rem;"></i>
                    </div>
                    <div>
                        <h2 class="fw-bold text-white mb-1">@Model.FullName</h2>
                        <p class="text-white-50 mb-0">
                            <i class="bi bi-envelope me-1"></i> @Model.Email
                        </p>
                        <p class="text-white-50 mb-0 small">
                            <i class="bi bi-calendar3 me-1"></i> Katılım: @Model.JoinedAt.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #e3f2fd, #bbdefb);">
            <div class="card-body p-3 p-md-4 text-center">
                <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-2" style="width: 48px; height: 48px;">
                    <i class="bi bi-star-fill text-primary fs-5"></i>
                </div>
                <p class="text-muted small mb-1">Toplam Puan</p>
                <h3 class="fw-bold text-primary mb-0">@Model.TotalScore</h3>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #e8f5e9, #c8e6c9);">
            <div class="card-body p-3 p-md-4 text-center">
                <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-2" style="width: 48px; height: 48px;">
                    <i class="bi bi-check-circle-fill text-success fs-5"></i>
                </div>
                <p class="text-muted small mb-1">Tamamlanan Ödevler</p>
                <h3 class="fw-bold text-success mb-0">@Model.CompletedAssignmentCount<span class="fs-6 text-muted fw-normal">/@Model.TotalAssignmentCount</span></h3>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #fff3e0, #ffe0b2);">
            <div class="card-body p-3 p-md-4 text-center">
                <div class="rounded-circle bg-warning bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-2" style="width: 48px; height: 48px;">
                    <i class="bi bi-book-fill text-warning fs-5"></i>
                </div>
                <p class="text-muted small mb-1">Kayıtlı Sınıflar</p>
                <h3 class="fw-bold text-warning mb-0">@Model.EnrolledClassCount</h3>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #f3e5f5, #e1bee7);">
            <div class="card-body p-3 p-md-4 text-center">
                <div class="rounded-circle bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-2" style="width: 48px; height: 48px; background: rgba(156, 39, 176, 0.1);">
                    <i class="bi bi-graph-up-arrow fs-5" style="color: #9c27b0;"></i>
                </div>
                <p class="text-muted small mb-1">Başarı Oranı</p>
                <h3 class="fw-bold mb-0" style="color: #9c27b0;">%@Model.OverallSuccessRate</h3>
            </div>
        </div>
    </div>
</div>

<!-- Course Stats Table -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-bar-chart-line me-2 text-primary"></i> Derslere Göre Başarı
                </h5>
            </div>
            <div class="card-body px-4 pb-4 pt-2">
                @if (!Model.CourseStats.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2">Henüz ders kaydınız bulunmuyor.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Ders</th>
                                    <th>Sınıf</th>
                                    <th class="text-center">Puan</th>
                                    <th class="text-center">Sıralama</th>
                                    <th class="text-center">Ödev</th>
                                    <th style="min-width: 180px;">Başarı</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var stat in Model.CourseStats)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; min-width: 32px;">
                                                    <i class="bi bi-book text-primary small"></i>
                                                </div>
                                                <span class="fw-semibold">@stat.CourseName</span>
                                            </div>
                                        </td>
                                        <td>
                                            <a asp-action="ClassDetail" asp-route-id="@stat.ClassGroupId" class="text-decoration-none">
                                                @stat.ClassName
                                            </a>
                                        </td>
                                        <td class="text-center">
                                            <span class="fw-bold text-primary">@stat.TotalScore</span>
                                            <span class="text-muted small">/ @stat.MaxPossibleScore</span>
                                        </td>
                                        <td class="text-center">
                                            @if (stat.Rank <= 3)
                                            {
                                                <span class="badge bg-warning text-dark px-2 py-1">
                                                    <i class="bi bi-trophy-fill me-1"></i>#@stat.Rank
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary px-2 py-1">#@stat.Rank</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <span class="fw-semibold">@stat.CompletedCount</span>
                                            <span class="text-muted small">/ @stat.TotalCount</span>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1" style="height: 8px;">
                                                    @{
                                                        var barColor = stat.SuccessRate >= 70 ? "bg-success" :
                                                                       stat.SuccessRate >= 40 ? "bg-warning" : "bg-danger";
                                                    }
                                                    <div class="progress-bar @barColor" role="progressbar"
                                                         style="width: @stat.SuccessRate%"
                                                         aria-valuenow="@stat.SuccessRate" aria-valuemin="0" aria-valuemax="100">
                                                    </div>
                                                </div>
                                                <span class="small fw-semibold" style="min-width: 40px;">%@stat.SuccessRate</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Performance Chart -->
@if (Model.WeeklyScores.Any())
{
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-activity me-2 text-success"></i> Performans Grafiği
                    </h5>
                    <p class="text-muted small mb-0 mt-1">Haftalara göre aldığınız puanlar</p>
                </div>
                <div class="card-body px-4 pb-4">
                    <canvas id="performanceChart" height="100"></canvas>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @if (Model.WeeklyScores.Any())
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const ctx = document.getElementById('performanceChart').getContext('2d');

                const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklyScores.Select(w => w.Label)));
                const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklyScores.Select(w => w.Score)));

                const gradient = ctx.createLinearGradient(0, 0, 0, 300);
                gradient.addColorStop(0, 'rgba(102, 126, 234, 0.8)');
                gradient.addColorStop(1, 'rgba(118, 75, 162, 0.4)');

                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Puan',
                            data: data,
                            backgroundColor: gradient,
                            borderColor: 'rgba(102, 126, 234, 1)',
                            borderWidth: 1,
                            borderRadius: 6,
                            borderSkipped: false
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: 'rgba(0, 0, 0, 0.8)',
                                titleFont: { size: 13 },
                                bodyFont: { size: 12 },
                                padding: 12,
                                cornerRadius: 8,
                                callbacks: {
                                    label: function (context) {
                                        return ' Puan: ' + context.parsed.y;
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: 'rgba(0, 0, 0, 0.05)' },
                                ticks: { font: { size: 12 } }
                            },
                            x: {
                                grid: { display: false },
                                ticks: {
                                    font: { size: 11 },
                                    maxRotation: 45,
                                    minRotation: 20
                                }
                            }
                        }
                    }
                });
            });
        </script>
    }
}
