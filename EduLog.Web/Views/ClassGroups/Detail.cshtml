@model EduLog.Web.ViewModels.ClassGroupDetailViewModel
@{
    ViewData["Title"] = Model.Name + " — Sınıf Detayı";
    Layout = "~/Views/Shared/_LayoutInstructor.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">
            <i class="bi bi-people me-2"></i> @Model.Name
        </h3>
        <p class="text-muted mb-0">@Model.CourseName — @Model.SyllabusTitle</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Sınıflara Dön
    </a>
</div>

<!-- Top Info Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body p-4">
                <p class="text-muted small mb-2">Sınıf Katılım Kodu</p>
                <div class="d-flex justify-content-center align-items-center gap-2">
                    <span id="joinCodeText" class="font-monospace fw-bold text-dark" style="font-size: 2.2rem; letter-spacing: 6px;">@Model.JoinCode</span>
                </div>
                <button class="btn btn-outline-primary btn-sm mt-3" onclick="copyJoinCode()">
                    <i class="bi bi-clipboard me-1"></i> Kopyala
                </button>
            </div>
        </div>
    </div>

    <!-- Week Panel -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body p-4">
                <p class="text-muted small mb-2">Ders Durumu</p>
                <div class="mb-2">
                    <span class="fs-1 fw-bold text-primary">@Model.CurrentWeek</span>
                    <span class="text-muted fs-5"> / @Model.MaxWeek</span>
                </div>
                @if (Model.CurrentWeek < Model.MaxWeek)
                {
                    <form asp-action="AdvanceWeek" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-success btn-sm"
                                onclick="return confirm('Ders @(Model.CurrentWeek + 1) açılacak. Devam etmek istiyor musunuz?');">
                            <i class="bi bi-unlock me-1"></i> Sonraki Dersi Aç
                        </button>
                    </form>
                }
                else
                {
                    <span class="badge bg-success px-3 py-2">
                        <i class="bi bi-check-circle me-1"></i> Tüm Dersler Açık
                    </span>
                }
            </div>
        </div>
    </div>

    <!-- Student Count -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body p-4">
                <p class="text-muted small mb-2">Kayıtlı Öğrenci</p>
                <span class="fs-1 fw-bold text-info">@Model.Students.Count</span>
                <p class="text-muted small mt-1">öğrenci</p>
            </div>
        </div>
    </div>

    <!-- Ungraded CodeTask -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body p-4">
                <p class="text-muted small mb-2">Puanlanmamış Teslim</p>
                @if (Model.UngradedCodeTaskCount > 0)
                {
                    <span class="fs-1 fw-bold text-danger">@Model.UngradedCodeTaskCount</span>
                    <p class="mt-1"><span class="badge bg-danger px-3 py-2"><i class="bi bi-exclamation-triangle me-1"></i> Değerlendirme Bekliyor</span></p>
                }
                else
                {
                    <span class="fs-1 fw-bold text-success">0</span>
                    <p class="mt-1"><span class="badge bg-success px-3 py-2"><i class="bi bi-check-circle me-1"></i> Hepsi Puanlandı</span></p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Tabs: Öğrenciler / Teslimler / Sıralama / Genel Bakış -->
<ul class="nav nav-tabs mb-0" id="classDetailTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="students-tab" data-bs-toggle="tab" data-bs-target="#studentsPane" type="button" role="tab">
            <i class="bi bi-person-lines-fill me-1"></i> Öğrenci Listesi (@Model.Students.Count)
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="submissions-tab" data-bs-toggle="tab" data-bs-target="#submissionsPane" type="button" role="tab">
            <i class="bi bi-inbox me-1"></i> Teslimler (@Model.Submissions.Count)
            @if (Model.UngradedCodeTaskCount > 0)
            {
                <span class="badge bg-danger ms-1">@Model.UngradedCodeTaskCount</span>
            }
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="leaderboard-tab" data-bs-toggle="tab" data-bs-target="#leaderboardPane" type="button" role="tab">
            <i class="bi bi-trophy me-1"></i> Sıralama
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overviewPane" type="button" role="tab">
            <i class="bi bi-bar-chart me-1"></i> Genel Bakış
        </button>
    </li>
</ul>

<div class="tab-content">
    <!-- Öğrenci Listesi Tab -->
    <div class="tab-pane fade show active" id="studentsPane" role="tabpanel">
        <div class="card border-0 shadow-sm border-top-0" style="border-top-left-radius: 0; border-top-right-radius: 0;">
            <div class="card-body p-0">
                @if (!Model.Students.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-person-x text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2">Henüz kayıtlı öğrenci yok.</p>
                        <p class="text-muted small">Öğrenciler <strong>@Model.JoinCode</strong> kodu ile kayıt olabilir.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">#</th>
                                    <th>Ad Soyad</th>
                                    <th>E-posta</th>
                                    <th>Katılım Tarihi</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int index = 1; }
                                @foreach (var student in Model.Students)
                                {
                                    <tr>
                                        <td class="ps-4">@index</td>
                                        <td class="fw-semibold">@student.FullName</td>
                                        <td class="text-muted">@student.Email</td>
                                        <td class="text-muted">@student.JoinedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                    index++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Teslimler Tab -->
    <div class="tab-pane fade" id="submissionsPane" role="tabpanel">
        <div class="card border-0 shadow-sm border-top-0" style="border-top-left-radius: 0; border-top-right-radius: 0;">
            @{
                var ungradedCodeTasks = Model.Submissions.Where(s => s.AssignmentType == "CodeTask" && !s.Score.HasValue).ToList();
            }
            @if (ungradedCodeTasks.Any())
            {
                <div class="card-header bg-white py-3 px-4 d-flex justify-content-between align-items-center border-bottom">
                    <span class="text-muted small">
                        <i class="bi bi-exclamation-circle me-1"></i>
                        <strong>@ungradedCodeTasks.Count</strong> adet puanlanmamış kod teslimi var
                    </span>
                    <div class="d-flex align-items-center gap-2">
                        <select id="bulkAiProvider" class="form-select form-select-sm" style="width: auto;">
                            <option value="anthropic">Claude</option>
                            <option value="gemini" selected>Gemini</option>
                        </select>
                        <button type="button" class="btn btn-warning btn-sm fw-semibold" id="btnBulkAIReview" onclick="startBulkAIReview()">
                            <i class="bi bi-robot me-1"></i> Tümünü AI ile İncele ve Kaydet
                        </button>
                    </div>
                </div>
            }
            <div class="card-body p-0">
                @if (!Model.Submissions.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2">Henüz teslim yapılmamış.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Öğrenci</th>
                                    <th>Ödev</th>
                                    <th>Tür</th>
                                    <th>İçerik</th>
                                    <th>Teslim Zamanı</th>
                                    <th>Puan</th>
                                    <th>İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sub in Model.Submissions)
                                {
                                    <tr>
                                        <td class="ps-4 fw-semibold">@sub.StudentName</td>
                                        <td>@sub.AssignmentTitle</td>
                                        <td>
                                            <span class="badge @(sub.AssignmentType == "CodeTask" ? "bg-warning" : "bg-info")">
                                                @(sub.AssignmentType == "CodeTask" ? "Kodlama" : "Quiz")
                                            </span>
                                        </td>
                                        <td class="text-muted small" style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                            @sub.ContentPreview
                                        </td>
                                        <td class="text-muted">@sub.SubmittedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>
                                            @if (sub.Score.HasValue)
                                            {
                                                <span class="badge bg-success">@sub.Score / @sub.MaxScore</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Bekliyor</span>
                                            }
                                        </td>
                                        <td>
                                            @if (sub.AssignmentType == "CodeTask" && !sub.Score.HasValue)
                                            {
                                                <a asp-action="GradeSubmission" asp-route-id="@sub.Id"
                                                   class="btn btn-outline-primary btn-sm">
                                                    <i class="bi bi-pencil me-1"></i> Puanla
                                                </a>
                                            }
                                            else if (sub.AssignmentType == "CodeTask" && sub.Score.HasValue)
                                            {
                                                <a asp-action="GradeSubmission" asp-route-id="@sub.Id"
                                                   class="btn btn-outline-secondary btn-sm">
                                                    <i class="bi bi-pencil me-1"></i> Düzenle
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Sıralama (Leaderboard) Tab -->
    <div class="tab-pane fade" id="leaderboardPane" role="tabpanel">
        <div class="card border-0 shadow-sm border-top-0" style="border-top-left-radius: 0; border-top-right-radius: 0;">
            <div class="card-body">
                @if (!Model.Leaderboard.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-trophy text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2">Henüz sıralama verisi yok.</p>
                    </div>
                }
                else
                {
                    <!-- Podium: Top 3 -->
                    @if (Model.Leaderboard.Count >= 1)
                    {
                        <div class="row justify-content-center mb-4 align-items-end">
                            @if (Model.Leaderboard.Count >= 2)
                            {
                                <!-- 2nd Place -->
                                <div class="col-md-3 text-center">
                                    <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #e8e8e8, #c0c0c0);">
                                        <div class="card-body py-4">
                                            <span style="font-size: 2.5rem;">🥈</span>
                                            <h5 class="fw-bold mt-2 mb-1">@Model.Leaderboard[1].FullName</h5>
                                            <span class="badge bg-dark fs-6 px-3 py-2">@Model.Leaderboard[1].TotalScore puan</span>
                                            <p class="text-muted small mt-2 mb-0">@Model.Leaderboard[1].SubmissionCount teslim</p>
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- 1st Place -->
                            <div class="col-md-4 text-center">
                                <div class="card border-0 shadow" style="background: linear-gradient(135deg, #fff8e1, #ffd54f);">
                                    <div class="card-body py-5">
                                        <span style="font-size: 3rem;">🥇</span>
                                        <h4 class="fw-bold mt-2 mb-1">@Model.Leaderboard[0].FullName</h4>
                                        <span class="badge bg-warning text-dark fs-5 px-3 py-2">@Model.Leaderboard[0].TotalScore puan</span>
                                        <p class="text-muted small mt-2 mb-0">@Model.Leaderboard[0].SubmissionCount teslim</p>
                                    </div>
                                </div>
                            </div>

                            @if (Model.Leaderboard.Count >= 3)
                            {
                                <!-- 3rd Place -->
                                <div class="col-md-3 text-center">
                                    <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #fff3e0, #ffab40);">
                                        <div class="card-body py-4">
                                            <span style="font-size: 2.5rem;">🥉</span>
                                            <h5 class="fw-bold mt-2 mb-1">@Model.Leaderboard[2].FullName</h5>
                                            <span class="badge bg-dark fs-6 px-3 py-2">@Model.Leaderboard[2].TotalScore puan</span>
                                            <p class="text-muted small mt-2 mb-0">@Model.Leaderboard[2].SubmissionCount teslim</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <!-- Full Leaderboard Table -->
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4" style="width: 60px;">Sıra</th>
                                    <th>Ad Soyad</th>
                                    <th>Toplam Puan</th>
                                    <th>Teslim Sayısı</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in Model.Leaderboard)
                                {
                                    <tr class="@(entry.Rank <= 3 ? "table-warning fw-semibold" : "")">
                                        <td class="ps-4">
                                            @if (entry.Rank == 1)
                                            {
                                                <span>🥇</span>
                                            }
                                            else if (entry.Rank == 2)
                                            {
                                                <span>🥈</span>
                                            }
                                            else if (entry.Rank == 3)
                                            {
                                                <span>🥉</span>
                                            }
                                            else
                                            {
                                                @entry.Rank
                                            }
                                        </td>
                                        <td>@entry.FullName</td>
                                        <td><span class="badge bg-primary">@entry.TotalScore</span></td>
                                        <td>@entry.SubmissionCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Genel Bakış Tab -->
    <div class="tab-pane fade" id="overviewPane" role="tabpanel">
        <div class="card border-0 shadow-sm border-top-0" style="border-top-left-radius: 0; border-top-right-radius: 0;">
            <div class="card-body">
                @if (!Model.WeekStats.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-bar-chart text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2">Henüz açılmış ders yok.</p>
                    </div>
                }
                else
                {
                    <h5 class="fw-bold mb-3"><i class="bi bi-calendar-week me-2"></i> Ders Bazında Teslim Durumu</h5>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Ders</th>
                                    <th>Konu</th>
                                    <th>Teslim Eden Öğrenci</th>
                                    <th>Oran</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ws in Model.WeekStats)
                                {
                                    var ratio = Model.Students.Count > 0
                                        ? (double)ws.StudentsSubmittedCount / Model.Students.Count * 100
                                        : 0;
                                    <tr>
                                        <td class="ps-4">
                                            <span class="badge bg-secondary">Ders @ws.WeekNumber</span>
                                        </td>
                                        <td>@ws.Topic</td>
                                        <td>
                                            <span class="fw-semibold">@ws.StudentsSubmittedCount</span>
                                            <span class="text-muted">/ @Model.Students.Count</span>
                                        </td>
                                        <td>
                                            <div class="progress" style="height: 20px; min-width: 120px;">
                                                <div class="progress-bar @(ratio >= 80 ? "bg-success" : ratio >= 50 ? "bg-warning" : "bg-danger")"
                                                     style="width: @((int)ratio)%;">
                                                    @((int)ratio)%
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Toplu AI İnceleme Modal -->
<div class="modal fade" id="bulkAIReviewModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-robot me-2"></i> Toplu AI İnceleme
                </h5>
            </div>
            <div class="modal-body">
                <!-- Loading -->
                <div id="bulkLoading">
                    <div class="text-center py-4">
                        <div class="spinner-border text-warning" role="status" style="width: 3rem; height: 3rem;">
                            <span class="visually-hidden">Yükleniyor...</span>
                        </div>
                        <p class="text-muted mt-3 mb-1">Tüm teslimler AI ile inceleniyor, lütfen bekleyin...</p>
                        <p class="text-muted small">Bu işlem birkaç dakika sürebilir.</p>
                    </div>
                    <div class="progress mx-4" style="height: 8px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-warning" id="bulkProgressBar" style="width: 100%;"></div>
                    </div>
                </div>

                <!-- Error -->
                <div id="bulkError" class="d-none">
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <span id="bulkErrorText"></span>
                    </div>
                </div>

                <!-- Results -->
                <div id="bulkResults" class="d-none">
                    <div class="row g-3 mb-4">
                        <div class="col-4 text-center">
                            <div class="card border-0 bg-light">
                                <div class="card-body py-3">
                                    <p class="text-muted small mb-1">Toplam</p>
                                    <span class="fs-3 fw-bold" id="bulkTotalCount">0</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-4 text-center">
                            <div class="card border-0" style="background-color: #d4edda;">
                                <div class="card-body py-3">
                                    <p class="text-muted small mb-1">Başarılı</p>
                                    <span class="fs-3 fw-bold text-success" id="bulkSuccessCount">0</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-4 text-center">
                            <div class="card border-0" style="background-color: #f8d7da;">
                                <div class="card-body py-3">
                                    <p class="text-muted small mb-1">Başarısız</p>
                                    <span class="fs-3 fw-bold text-danger" id="bulkFailCount">0</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Öğrenci</th>
                                    <th>Ödev</th>
                                    <th>Puan</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody id="bulkResultsBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer" id="bulkFooter" style="display: none;">
                <button type="button" class="btn btn-primary" onclick="location.reload()">
                    <i class="bi bi-arrow-clockwise me-1"></i> Sayfayı Yenile
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyJoinCode() {
            var code = document.getElementById('joinCodeText').textContent.trim();
            navigator.clipboard.writeText(code).then(function () {
                var btn = event.target.closest('button');
                var originalHtml = btn.innerHTML;
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> Kopyalandı!';
                btn.classList.remove('btn-outline-primary');
                btn.classList.add('btn-success');
                setTimeout(function () {
                    btn.innerHTML = originalHtml;
                    btn.classList.remove('btn-success');
                    btn.classList.add('btn-outline-primary');
                }, 2000);
            });
        }

        function startBulkAIReview() {
            var modal = new bootstrap.Modal(document.getElementById('bulkAIReviewModal'));
            document.getElementById('bulkLoading').classList.remove('d-none');
            document.getElementById('bulkError').classList.add('d-none');
            document.getElementById('bulkResults').classList.add('d-none');
            document.getElementById('bulkFooter').style.display = 'none';
            modal.show();

            var provider = document.getElementById('bulkAiProvider').value;
            var formData = new FormData();
            formData.append('classGroupId', @Model.Id);
            formData.append('provider', provider);

            fetch('@Url.Action("BulkAIReviewSubmissions", "ClassGroups")', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                document.getElementById('bulkLoading').classList.add('d-none');

                if (data.success && data.results) {
                    document.getElementById('bulkTotalCount').textContent = data.totalCount || 0;
                    document.getElementById('bulkSuccessCount').textContent = data.successCount || 0;
                    document.getElementById('bulkFailCount').textContent = data.failCount || 0;

                    var tbody = document.getElementById('bulkResultsBody');
                    tbody.innerHTML = '';

                    if (data.results.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">Puanlanmamış kod teslimi bulunamadı.</td></tr>';
                    } else {
                        data.results.forEach(function(r) {
                            var statusBadge = r.success
                                ? '<span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Başarılı</span>'
                                : '<span class="badge bg-danger" title="' + (r.error || '') + '"><i class="bi bi-x-circle me-1"></i>Hata</span>';
                            var scoreText = r.success ? (r.score + ' / ' + r.maxScore) : '-';
                            tbody.innerHTML += '<tr>' +
                                '<td class="ps-3 fw-semibold">' + r.studentName + '</td>' +
                                '<td>' + r.assignmentTitle + '</td>' +
                                '<td>' + scoreText + '</td>' +
                                '<td>' + statusBadge + '</td>' +
                                '</tr>';
                        });
                    }

                    document.getElementById('bulkResults').classList.remove('d-none');
                    document.getElementById('bulkFooter').style.display = 'flex';
                } else {
                    document.getElementById('bulkErrorText').textContent = data.error || data.message || 'Bilinmeyen bir hata oluştu.';
                    document.getElementById('bulkError').classList.remove('d-none');
                    document.getElementById('bulkFooter').style.display = 'flex';
                }
            })
            .catch(error => {
                document.getElementById('bulkLoading').classList.add('d-none');
                document.getElementById('bulkErrorText').textContent = 'Bağlantı hatası: ' + error.message;
                document.getElementById('bulkError').classList.remove('d-none');
                document.getElementById('bulkFooter').style.display = 'flex';
            });
        }
    </script>
}
