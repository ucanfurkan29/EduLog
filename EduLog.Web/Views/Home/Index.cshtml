@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EduLog — Eğitim Yönetim Platformu</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        .hero-section {
            background: linear-gradient(135deg, #0d6efd 0%, #6610f2 50%, #6f42c1 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        .feature-icon {
            width: 72px;
            height: 72px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>
    <!-- Hero Section -->
    <section class="hero-section text-white">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-5 mb-lg-0">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-mortarboard-fill fs-1"></i>
                        <span class="fs-3 fw-bold">EduLog</span>
                    </div>
                    <h1 class="display-4 fw-bold mb-3">Eğitim Yönetim<br />Platformu</h1>
                    <p class="lead opacity-75 mb-4">
                        Derslerinizi planlayın, müfredatlarınızı oluşturun, ödevlerinizi AI desteğiyle hazırlayın
                        ve öğrencilerinizin ilerlemesini takip edin.
                    </p>
                    <div class="d-flex gap-3">
                        <a href="@Url.Action("Login", "Account")" class="btn btn-light btn-lg px-4 fw-semibold">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Giriş Yap
                        </a>
                        <a href="@Url.Action("Register", "Account")" class="btn btn-outline-light btn-lg px-4">
                            <i class="bi bi-person-plus me-1"></i> Kayıt Ol
                        </a>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="row g-4">
                        <div class="col-6">
                            <div class="bg-white bg-opacity-10 rounded-4 p-4 text-center backdrop-blur">
                                <div class="feature-icon bg-white bg-opacity-25 mx-auto mb-3">
                                    <i class="bi bi-calendar-week text-white fs-2"></i>
                                </div>
                                <h5 class="fw-bold mb-1">Haftalık Müfredat</h5>
                                <p class="small opacity-75 mb-0">Dersleri hafta hafta planlayın</p>
                            </div>
                        </div>
                        <div class="col-6 mt-5">
                            <div class="bg-white bg-opacity-10 rounded-4 p-4 text-center">
                                <div class="feature-icon bg-white bg-opacity-25 mx-auto mb-3">
                                    <i class="bi bi-robot text-white fs-2"></i>
                                </div>
                                <h5 class="fw-bold mb-1">AI Ödev Üretimi</h5>
                                <p class="small opacity-75 mb-0">Claude ile otomatik sorular</p>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="bg-white bg-opacity-10 rounded-4 p-4 text-center">
                                <div class="feature-icon bg-white bg-opacity-25 mx-auto mb-3">
                                    <i class="bi bi-trophy text-white fs-2"></i>
                                </div>
                                <h5 class="fw-bold mb-1">Sıralama Tablosu</h5>
                                <p class="small opacity-75 mb-0">Öğrenci başarı takibi</p>
                            </div>
                        </div>
                        <div class="col-6 mt-n3">
                            <div class="bg-white bg-opacity-10 rounded-4 p-4 text-center">
                                <div class="feature-icon bg-white bg-opacity-25 mx-auto mb-3">
                                    <i class="bi bi-people text-white fs-2"></i>
                                </div>
                                <h5 class="fw-bold mb-1">Sınıf Yönetimi</h5>
                                <p class="small opacity-75 mb-0">Katılım kodlu sınıf sistemi</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
